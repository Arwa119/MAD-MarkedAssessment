<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Event Registration"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fill in your details below"
            android:textSize="13sp"
            android:textColor="#888"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Full Name *"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etFullName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter your full name"
            android:inputType="textPersonName"
            android:layout_marginBottom="16dp"
            android:padding="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Phone Number *"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. 03001234567"
            android:inputType="phone"
            android:layout_marginBottom="16dp"
            android:padding="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email Address *"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="example@email.com"
            android:inputType="textEmailAddress"
            android:layout_marginBottom="16dp"
            android:padding="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Event Type *"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333"
            android:layout_marginBottom="4dp"/>
        <Spinner
            android:id="@+id/spinnerEventType"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Event Date *"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333"
            android:layout_marginBottom="4dp"/>
        <Button
            android:id="@+id/btnPickDate"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Select Event Date"
            android:backgroundTint="#E8EAF6"
            android:textColor="#1A237E"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>
        <TextView
            android:id="@+id/tvSelectedDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No date selected"
            android:textSize="13sp"
            android:textColor="#999"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gender *"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333"
            android:layout_marginBottom="4dp"/>
        <RadioGroup
            android:id="@+id/rgGender"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/rbMale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Male"
                android:textColor="#333"
                android:textSize="15sp"
                android:layout_marginEnd="20dp"/>

            <RadioButton
                android:id="@+id/rbFemale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Female"
                android:textColor="#333"
                android:textSize="15sp"
                android:layout_marginEnd="20dp"/>

            <RadioButton
                android:id="@+id/rbOther"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Other"
                android:textColor="#333"
                android:textSize="15sp"/>
        </RadioGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile / Event Image"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333"
            android:layout_marginBottom="10dp"/>

        <ImageView
            android:id="@+id/ivProfileImage"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery"
            android:background="#E8EAF6"
            android:padding="10dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"
            android:contentDescription="Selected Profile Image"/>

        <Button
            android:id="@+id/btnUploadImage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📷  Choose Image"
            android:backgroundTint="#E8EAF6"
            android:textColor="#1A237E"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp"/>

        <!-- ===== TERMS ===== -->
        <CheckBox
            android:id="@+id/cbTerms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="I accept the Terms and Conditions"
            android:textSize="14sp"
            android:textColor="#333"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnSubmit"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Submit Registration"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#1A237E"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>